# Database (TiDB Cloud or local MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=esl_booking
DB_PORT=3306
DB_SSL=false

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=

# Super Admin credentials (set on first run)
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Frontend URL (required in production for CORS)
FRONTEND_URL=http://localhost:3000

# SMTP (optional - leave empty to log reset links to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Sentry (optional)
SENTRY_DSN=
LOG_LEVEL=info

# Node environment
NODE_ENV=development
